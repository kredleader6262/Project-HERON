# Alpaca API (paper)
ALPACA_API_KEY=your-paper-api-key
ALPACA_SECRET_KEY=your-paper-secret-key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Claude API
ANTHROPIC_API_KEY=your-claude-api-key
# Optional: override default Claude model IDs (defaults shown)
# CLAUDE_SONNET_MODEL=claude-sonnet-4-6
# CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001

# Discord alerts (M12) — leave blank to disable
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook
DISCORD_WEBHOOK_URL=
DASHBOARD_URL=http://localhost:5001

# SEC EDGAR (required — use a real email)
SEC_USER_AGENT=HERON-research your-email@example.com

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M
